# =============================================
# 雷犀IT资产管理系统 - 环境配置
# =============================================

# =============================================
# MySQL 数据库配置
# =============================================

# MySQL 容器内部端口（一般不需要修改）
MYSQL_PORT=3306

# MySQL 宿主机映射端口（外部访问端口）
# 如果本地已有 MySQL 占用 3306，改成其他端口，如 3307
MYSQL_HOST_PORT=3307

# MySQL 主机名（Docker 内部服务名，不需要修改）
MYSQL_HOST=mysql

# MySQL 数据库名
MYSQL_DATABASE=ciyo_itam

# MySQL root 密码
MYSQL_ROOT_PASSWORD=root123456

# MySQL 业务用户
MYSQL_USER=ciyo

# MySQL 业务用户密码
MYSQL_PASSWORD=ciyo123456

# =============================================
# Spring Boot 后端配置
# =============================================

# 后端运行环境
SPRING_PROFILES_ACTIVE=prod

# 后端监听地址
APP_HOST=0.0.0.0

# 后端容器内部端口
APP_PORT=8088

# 后端宿主机映射端口（外部访问端口）
# 如果本地 8088 被占用，改成其他端口，如 8089
APP_HOST_PORT=8088

# =============================================
# Nginx 前端配置
# =============================================

# 域名/访问地址配置
# 本地内网环境：使用服务器 IP 或 localhost
# 如果用 localhost，浏览器直接访问 http://localhost
# 如果用内网 IP，如 http://192.168.1.100
DOMAIN_NAME=http://manage.leixi.com

# Nginx HTTP 宿主机映射端口（外部访问端口）
# 如果本地 80 被占用，改成其他端口，如 8080
NGINX_HTTP_HOST_PORT=80

# Nginx HTTPS 宿主机映射端口
NGINX_HTTPS_HOST_PORT=443

# 是否启用 HTTPS（生产环境设为 true）
ENABLE_HTTPS=false

# SSL 证书路径（ENABLE_HTTPS=true 时使用）
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_CERT_KEY_PATH=/etc/nginx/ssl/key.pem

# =============================================
# 前端构建配置
# =============================================

# 前端 API 前缀
VITE_APP_BASE_API=/api

# 前端应用标题
VITE_APP_TITLE=雷犀IT资产管理

# =============================================
# Redis 配置
# =============================================

# Redis 容器内部端口
REDIS_PORT=6379

# Redis 宿主机映射端口（外部访问端口）
# 如果本地 6379 被占用，改成其他端口
REDIS_HOST_PORT=6379

# Redis 主机名（Docker 内部服务名）
REDIS_HOST=redis

# Redis 密码（无密码则留空）
REDIS_PASSWORD=

# =============================================
# Docker 配置
# =============================================

# Docker Compose 项目名称
COMPOSE_PROJECT_NAME=ciyo-itasset

# =============================================
# 安全配置
# =============================================

# AES 加密密钥（生产环境必须设置）
# 使用命令生成: openssl rand -base64 32
# 注意: 此密钥用于密码加密，如果更换密钥，已加密的密码将无法解密
CIYO_SECURITY_AES_KEY=CiyoCloud@2024#IT&Asset!Secure
# 旧 AES 密钥（用于密码迁移，首次部署与 AES_KEY 相同）
CIYO_SECURITY_AES_KEY_OLD=CiyoCloud@2024#IT&Asset!Secure
# CORS 允许来源（开发环境留空，生产环境设置具体域名）
CORS_ALLOWED_ORIGINS=http://manage.leixi.com
